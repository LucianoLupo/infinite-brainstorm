4","group":"bookstore"},{"id":"g7_address","x":5200.0,"y":2750.0,"width":220.0,"height":130.0,"text":"«weak» ADDRESS\nPK(part) line1\nFK customer_id\n   city","node_type":"note","color":"#f59e0b","group":"bookstore"},{"id":"g7_orderitem","x":5550.0,"y":2700.0,"width":220.0,"height":130.0,"text":"ORDER_ITEM (junction)\nFK order_id\nFK book_id\n   qty","node_type":"note","color":"#f59e0b","group":"bookstore"},{"id":"g8___hdr","x":7800.0,"y":2100.0,"width":560.0,"height":120.0,"text":"# Data Flow Diagram\n*processes, stores, data packets*","node_type":"md","color":"#475569"},{"id":"g8_title","x":8160.0,"y":2270.0,"width":520.0,"height":90.0,"text":"# DFD (Level 1) — Order Processing\n\n*Data flow diagram · context + level-1 · edges carry **data packets** (nouns), never actions*","node_type":"md"},{"id":"g8_legend","x":9260.0,"y":2800.0,"width":320.0,"height":280.0,"text":"## Legend\n\n- **🟩 Process** (`idea`) — number + verb name\n- **🟨 External entity** (`note`) — `«external»`, sits OUTSIDE the boundary\n- **🟦 Data store** (`text`) — `‹‹store›› Dn`\n- **→ Data flow** (edge) — labeled with the **data name** (a noun packet)\n- **┄ Boundary** = `group: system boundary`","node_type":"md"},{"id":"g8_customer","x":7800.0,"y":2520.0,"width":200.0,"height":110.0,"text":"«external» Customer","node_type":"note","color":"#f59e0b"},{"id":"g8_provider","x":9260.0,"y":2520.0,"width":200.0,"height":110.0,"text":"«external» Payment Provider","node_type":"note","color":"#f59e0b"},{"id":"g8_validate","x":8160.0,"y":2520.0,"width":220.0,"height":110.0,"text":"1\nValidate Order","node_type":"idea","color":"#22c55e","tags":["level-1"],"group":"system boundary"},{"id":"g8_charge","x":8510.0,"y":2520.0,"width":220.0,"height":110.0,"text":"2\nCharge Payment","node_type":"idea","color":"#22c55e","tags":["level-1"],"group":"system boundary"},{"id":"g8_d1","x":8160.0,"y":2820.0,"width":220.0,"height":100.0,"text":"‹‹store›› D1 Orders","node_type":"text","color":"#06b6d4","group":"system boundary"},{"id":"g8_d2","x":8510.0,"y":2820.0,"width":220.0,"height":100.0,"text":"‹‹store›› D2 Payments","node_type":"text","color":"#06b6d4","group":"system boundary"},{"id":"g9___hdr","x":10400.0,"y":2100.0,"width":560.0,"height":120.0,"text":"# Microservices Service Map\n*sync/async coupling, DB-per-service*","node_type":"md","color":"#475569"},{"id":"g9_title","x":10400.0,"y":2310.0,"width":420.0,"height":100.0,"text":"# Service Map — Food Delivery\n\n*Service-dependency map · each service owns its own DB · sync vs async shown in edge labels*","node_type":"md"},{"id":"g9_legend","x":11400.0,"y":2270.0,"width":420.0,"height":300.0,"text":"## Legend\n\n- **🟩 Service** — `idea` `#22c55e` (a deployable bounded context)\n- **🟦 DB-per-service** — `text [DB]` `#06b6d4`, **never shared**\n- **🟪 Gateway / Broker** — `text` `#a855f7`, `«gateway»` / `[BUS]`\n- **⬜ External** — `text [External]` `#9ca3af`\n- **Edges**: `sync:` (REST/HTTPS, blocking) vs `async:` (event/publish)\n- **`group`** = bounded context / owning team","node_type":"md"},{"id":"g9_gw","x":10400.0,"y":2710.0,"width":220.0,"height":110.0,"text":"«gateway» API Gateway\n[Edge / routing · authN]","node_type":"text","color":"#a855f7","group":"edge"},{"id":"g9_order","x":10750.0,"y":2510.0,"width":220.0,"height":110.0,"text":"Order Service\n[owns order lifecycle]","node_type":"idea","color":"#22c55e","group":"order"},{"id":"g9_restaurant","x":10750.0,"y":2710.0,"width":220.0,"height":110.0,"text":"Restaurant Service\n[menus · availability]","node_type":"idea","color":"#22c55e","group":"restaurant"},{"id":"g9_delivery","x":10750.0,"y":2910.0,"width":220.0,"height":110.0,"text":"Delivery Service\n[dispatch · tracking]","node_type":"idea","color":"#22c55e","group":"delivery"},{"id":"g9_payment","x":10750.0,"y":3110.0,"width":220.0,"height":110.0,"text":"Payment Service\n[charges · refunds]","node_type":"idea","color":"#22c55e","group":"payment"},{"id":"g9_orderdb","x":11100.0,"y":2550.0,"width":200.0,"height":90.0,"text":"[DB] orders-db\n[PostgreSQL]","node_type":"text","color":"#06b6d4","group":"order"},{"id":"g9_restdb","x":11100.0,"y":2750.0,"width":200.0,"height":90.0,"text":"[DB] restaurant-db\n[PostgreSQL]","node_type":"text","color":"#06b6d4","group":"restaurant"},{"id":"g9_deldb","x":11100.0,"y":2950.0,"width":200.0,"height":90.0,"text":"[DB] delivery-db\n[PostgreSQL]","node_type":"text","color":"#06b6d4","group":"delivery"},{"id":"g9_paydb","x":11100.0,"y":3150.0,"width":200.0,"height":90.0,"text":"[DB] payment-db\n[PostgreSQL]","node_type":"text","color":"#06b6d4","group":"payment"},{"id":"g9_stripe","x":11400.0,"y":3110.0,"width":200.0,"height":90.0,"text":"[External] Stripe API\n[card processing]","node_type":"text","color":"#9ca3af"},{"id":"g10___hdr","x":0.0,"y":4200.0,"width":560.0,"height":120.0,"text":"# Event-Driven Flow\n*producers → broker → consumers*","node_type":"md","color":"#475569"},{"id":"g10_title","x":0.0,"y":4370.0,"width":500.0,"height":80.0,"text":"# Event Flow — Order Pipeline\n*Event-driven architecture · pub/sub*","node_type":"md","color":"#a78bfa"},{"id":"g10_legend","x":1000.0,"y":4370.0,"width":420.0,"height":300.0,"text":"## Legend\n\n- **Service** — `idea` green, publishes/subscribes\n- **[BUS] Broker** — violet infra\n- **#topic** — cyan data store\n- **Event payload** — amber note\n- Edge label = `publishes X` / `on X`\n- `group` = bounded context","node_type":"md","color":"#a78bfa"},{"id":"g10_orderSvc","x":0.0,"y":4570.0,"width":220.0,"height":110.0,"text":"Order Service\n\nPublishes OrderPlaced when a customer checks out.","node_type":"idea","color":"#22c55e","group":"Ordering"},{"id":"g10_invSvc","x":0.0,"y":4890.0,"width":220.0,"height":110.0,"text":"Inventory Service\n\nSubscribes OrderPlaced, publishes StockReserved.","node_type":"idea","color":"#22c55e","group":"Inventory"},{"id":"g10_broker","x":360.0,"y":4530.0,"width":220.0,"height":80.0,"text":"[BUS] Kafka Broker","node_type":"text","color":"#a855f7","group":"Event Bus"},{"id":"g10_tOrders","x":360.0,"y":4660.0,"width":220.0,"height":90.0,"text":"#topic orders\n\nOrderPlaced events","node_type":"text","color":"#06b6d4","group":"Event Bus"},{"id":"g10_tStock","x":360.0,"y":4860.0,"width":220.0,"height":90.0,"text":"#topic stock\n\nStockReserved events","node_type":"text","color":"#06b6d4","group":"Event Bus"},{"id":"g10_notifySvc","x":720.0,"y":4570.0,"width":220.0,"height":110.0,"text":"Notification Service\n\nSubscribes OrderPlaced, e-mails the customer.","node_type":"idea","color":"#22c55e","group":"Notifications"},{"id":"g10_shipSvc","x":720.0,"y":4830.0,"width":220.0,"height":110.0,"text":"Shipping Service\n\nSubscribes StockReserved, schedules dispatch.","node_type":"idea","color":"#22c55e","group":"Shipping"},{"id":"g10_evtOrderPlaced","x":300.0,"y":5090.0,"width":200.0,"height":80.0,"text":"OrderPlaced\n{ orderId, items, total }","node_type":"note","color":"#f97316"},{"id":"g10_evtStockReserved","x":520.0,"y":5090.0,"width":200.0,"height":80.0,"text":"StockReserved\n{ orderId, reservationId }","node_type":"note","color":"#f97316"},{"id":"g11___hdr","x":2600.0,"y":4200.0,"width":560.0,"height":120.0,"text":"# Hexagonal (Ports & Adapters)\n*core behind ports; driving vs driven*","node_type":"md","color":"#475569"},{"id":"g11_title","x":2980.0,"y":4500.0,"width":420.0,"height":70.0,"text":"# Hexagonal — Order Service\n\n*Ports & Adapters · the Dependency Rule: every arrow points inward toward the core*","node_type":"md"},{"id":"g11_legend","x":2600.0,"y":4370.0,"width":360.0,"height":200.0,"text":"## Legend\n- **🟩 Core / Domain** (`#22c55e`) — use-cases & business rules; depends on nothing outside.\n- **🟦 «port»** (`#6366f1`) — an interface the core owns.\n- **🟧 «driving»** (`#f59e0b`, LEFT) — primary adapters that *call in*.\n- **⬜ «driven»** (`#9ca3af`, RIGHT) — secondary adapters the core *calls out* to; `[DB]` datastore is cyan `#06b6d4`.\n- Edges: adapter→port `implements`; everything points **inward**.","node_type":"md"},{"id":"g11_rest","x":2600.0,"y":4650.0,"width":200.0,"height":100.0,"text":"«driving» REST API\nHTTP controller — POST /orders","node_type":"note","color":"#f59e0b"},{"id":"g11_cli","x":2600.0,"y":4810.0,"width":200.0,"height":100.0,"text":"«driving» CLI\norder place …","node_type":"note","color":"#f59e0b"},{"id":"g11_test","x":2600.0,"y":4970.0,"width":200.0,"height":100.0,"text":"«driving» Test Harness\nDrives the core directly","node_type":"note","color":"#f59e0b"},{"id":"g11_pPlace","x":2870.0,"y":4820.0,"width":200.0,"height":80.0,"text":"«port» ForPlacingOrders","node_type":"link","color":"#6366f1"},{"id":"g11_core","x":3140.0,"y":4790.0,"width":260.0,"height":160.0,"text":"Application Core / Domain\nOrder use-cases, business rules.","node_type":"idea","color":"#22c55e"},{"id":"g11_pStore","x":3470.0,"y":4730.0,"width":200.0,"height":80.0,"text":"«port» ForStoringOrders","node_type":"link","color":"#6366f1"},{"id":"g11_pNotify","x":3470.0,"y":4910.0,"width":200.0,"height":80.0,"text":"«port» ForNotifying","node_type":"link","color":"#6366f1"},{"id":"g11_pg","x":3730.0,"y":4710.0,"width":220.0,"height":100.0,"text":"[DB] «driven» Postgres\nOrderRepository — SQL","node_type":"text","color":"#06b6d4"},{"id":"g11_smtp","x":3730.0,"y":4910.0,"width":220.0,"height":100.0,"text":"«driven» SMTP Email\nSends order confirmations","node_type":"text","color":"#9ca3af"},{"id":"g12___hdr","x":5200.0,"y":4200.0,"width":560.0,"height":120.0,"text":"# Deployment\n*what runs where, per environment*","node_type":"md","color":"#475569"},{"id":"g12_title","x":5200.0,"y":4370.0,"width":420.0,"height":90.0,"text":"# Deployment — Production (AWS)\n*UML/C4 deployment view · one environment per board · top-to-bottom DNS→ALB→API→DB*","node_type":"md"},{"id":"g12_legend","x":6100.0,"y":4370.0,"width":380.0,"height":320.0,"text":"## Legend\n\n- **«executionEnvironment»** (indigo `#6366f1`) — a deployment node header; the surrounding `group` box is the node boundary.\n- **Container instance** (green `#22c55e`) — a deployed artifact, with `×N instances`.\n- **Infra** (red `#ef4444`) — `[Load Balancer]` / `[DNS]` / `[Firewall]`.\n- **Datastore** (cyan `#06b6d4`) — `[DB]`.\n- Edge labels carry **protocol + port** (e.g. `[HTTPS/443]`).\n\nAll nodes `status: production`.","node_type":"md"},{"id":"g12_dns","x":5540.0,"y":4520.0,"width":200.0,"height":90.0,"text":"[DNS] Route 53","node_type":"text","color":"#ef4444","status":"production"},{"id":"g12_alb","x":5540.0,"y":4680.0,"width":220.0,"height":90.0,"text":"[Load Balancer] ALB\nForwards [HTTPS/443]","node_type":"text","color":"#ef4444","status":"production"},{"id":"g12_az_a_header","x":5240.0,"y":4840.0,"width":240.0,"height":90.0,"text":"«executionEnvironment» AZ us-east-1a\n[ECS Fargate]","node_type":"idea","color":"#6366f1","status":"production","group":"AWS / AZ us-east-1a"},{"id":"g12_az_b_header","x":5800.0,"y":4840.0,"width":240.0,"height":90.0,"text":"«executionEnvironment» AZ us-east-1b\n[ECS Fargate]","node_type":"idea","color":"#6366f1","status":"production","group":"AWS / AZ us-east-1b"},{"id":"g12_api_a","x":5240.0,"y":4960.0,"width":240.0,"height":110.0,"text":"Orders API\n[Container: Node.js]\n×3 instances","node_type":"idea","color":"#22c55e","status":"production","group":"AWS / AZ us-east-1a"},{"id":"g12_api_b","x":5800.0,"y":4960.0,"width":240.0,"height":110.0,"text":"Orders API\n[Container: Node.js]\n×3 instances","node_type":"idea","color":"#22c55e","status":"production","group":"AWS / AZ us-east-1b"},{"id":"g12_rds","x":5520.0,"y":5160.0,"width":260.0,"height":110.0,"text":"[DB] RDS PostgreSQL\n[Multi-AZ]","node_type":"text","color":"#06b6d4","status":"production"},{"id":"g13___hdr","x":7800.0,"y":4200.0,"width":560.0,"height":120.0,"text":"# ADR / Decision Log\n*why; status-colored decision chain*","node_type":"md","color":"#475569"},{"id":"g13_title","x":7800.0,"y":4370.0,"width":420.0,"height":110.0,"text":"# Decision Log — Payments Platform\n\n*Architecture Decision Records (Nygard format) · newest at top · supersession arrows point new → old*","node_type":"md"},{"id":"g13_legend","x":8270.0,"y":4370.0,"width":420.0,"height":250.0,"text":"## Legend — status → border color\n\n- 🟢 **Accepted** — `#22c55e`\n- 🟠 **Proposed** — `#f59e0b`\n- ⚪ **Superseded / Deprecated** — `#9ca3af`\n- 🔴 **Rejected** — `#ef4444`\n\n*Each ADR is an `md` node; `status` mirrors the label for `tag:`/`status:` filtering. Edge `supersedes` = newer ADR → the one it replaces.*","node_type":"md"},{"id":"g13_adr1","x":7800.0,"y":4570.0,"width":320.0,"height":220.0,"text":"# ADR-0001: Use PostgreSQL for the order store\n## Status\nAccepted\n## Context\nNeed ACID order persistence with strong consistency.\n## Decision\nWe will use PostgreSQL.\n## Consequences\n+ ACID, mature tooling. - Vertical scaling limits.","node_type":"md","color":"#22c55e","status":"accepted","group":"data"},{"id":"g13_adr2","x":7800.0,"y":4830.0,"width":320.0,"height":220.0,"text":"# ADR-0002: Async messaging via Kafka\n## Status\nAccepted\n## Context\nServices must decouple; sync chains caused cascading failures.\n## Decision\nWe will communicate via Kafka events.\n## Consequences\n+ Decoupling, replay. - Eventual consistency.","node_type":"md","color":"#22c55e","status":"accepted","group":"messaging"},{"id":"g13_adr3","x":8150.0,"y":5090.0,"width":320.0,"height":220.0,"text":"# ADR-0003: Synchronous REST between services\n## Status\nSuperseded by ADR-0002\n## Context\nInitial simple call model.\n## Decision\nWe will use REST for inter-service calls.\n## Consequences\n- Tight runtime coupling.","node_type":"md","color":"#9ca3af","status":"superseded","group":"messaging"},{"id":"g13_adr4","x":7800.0,"y":5350.0,"width":320.0,"height":220.0,"text":"# ADR-0004: Saga pattern for distributed transactions\n## Status\nProposed\n## Context\nDB-per-service blocks 2PC.\n## Decision\nWe will use orchestrated sagas with compensations.\n## Consequences\n+ Consistency without 2PC. - Compensation complexity.","node_type":"md","color":"#f59e0b","status":"proposed","group":"data"},{"id":"g14___hdr","x":10400.0,"y":4200.0,"width":560.0,"height":120.0,"text":"# Mind Map\n*central topic + radial branches*","node_type":"md","color":"#475569"},{"id":"g14_center","x":10750.0,"y":4650.0,"width":220.0,"height":100.0,"text":"Central Topic","node_type":"idea"},{"id":"g14_b1","x":11100.0,"y":4450.0,"width":200.0,"height":100.0,"text":"Branch 1","node_type":"text"},{"id":"g14_b2","x":11100.0,"y":4650.0,"width":200.0,"height":100.0,"text":"Branch 2","node_type":"text"},{"id":"g14_b3","x":11100.0,"y":4850.0,"width":200.0,"height":100.0,"text":"Branch 3","node_type":"text"},{"id":"g14_b4","x":10400.0,"y":4450.0,"width":200.0,"height":100.0,"text":"Branch 4","node_type":"text"},{"id":"g14_b5","x":10400.0,"y":4650.0,"width":200.0,"height":100.0,"text":"Branch 5","node_type":"text"},{"id":"g14_b6","x":10400.0,"y":4850.0,"width":200.0,"height":100.0,"text":"Branch 6","node_type":"text"},{"id":"g14_b1a","x":11400.0,"y":4370.0,"width":180.0,"height":80.0,"text":"Sub-idea 1a","node_type":"note"},{"id":"g14_b1b","x":11400.0,"y":4480.0,"width":180.0,"height":80.0,"text":"Sub-idea 1b","node_type":"note"},{"id":"g14_b2a","x":11400.0,"y":4600.0,"width":180.0,"height":80.0,"text":"Sub-idea 2a","node_type":"note"},{"id":"g14_b2b","x":11400.0,"y":4700.0,"width":180.0,"height":80.0,"text":"Sub-idea 2b","node_type":"note"},{"id":"g15___hdr","x":0.0,"y":6300.0,"width":560.0,"height":120.0,"text":"# Kanban\n*status columns*","node_type":"md","color":"#475569"},{"id":"g15_h-todo","x":0.0,"y":6470.0,"width":200.0,"height":60.0,"text":"To Do","node_type":"note","color":"#888888"},{"id":"g15_h-progress","x":250.0,"y":6470.0,"width":200.0,"height":60.0,"text":"In Progress","node_type":"note","color":"#3b82f6"},{"id":"g15_h-review","x":500.0,"y":6470.0,"width":200.0,"height":60.0,"text":"Review","node_type":"note","color":"#f59e0b"},{"id":"g15_h-done","x":750.0,"y":6470.0,"width":200.0,"height":60.0,"text":"Done","node_ty